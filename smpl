#!/usr/bin/env bash
# Find the exact directory where this script lives, matching %~dp0 semantics
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

PYTHON_CMD="python3"
if ! command -v "$PYTHON_CMD" >/dev/null 2>&1; then
  if command -v python >/dev/null 2>&1; then
    PYTHON_CMD="python"
  fi
fi

"$PYTHON_CMD" "$SCRIPT_DIR/smpl.py" "$@"
